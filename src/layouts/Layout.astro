---
import '@fontsource/merriweather/latin-400.css';
import '@fontsource/merriweather/latin-ext-400.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-ext-400.css';
import '../styles/global.css';

import FloatingBar from '../components/FloatingBar.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Máster Ejecutivo en Organización de Eventos & Wedding Planner - Instituto Osbord" } = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
const isCheckout = pathname === '/checkout' || pathname === '/checkout/' || pathname === '/registro' || pathname === '/registro/'; // Normalize check
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<!-- Critical Meta Tags FIRST (before any scripts) -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="EanYHzohzwMXIO-YxPw2MQP0hqSyQXgNYj3NDlW0i24" />

		<!-- Favicon -->
		<link rel="icon" type="image/webp" href="/images/logofaviconosbord.webp" />
		<link rel="apple-touch-icon" href="/images/logofaviconosbord.webp" />

		<!-- Preconnect to critical third-party domains -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://connect.facebook.net" />
		<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://connect.facebook.net" />

		<!-- Preload LCP Hero Image -->
		<link rel="preload" href="/.netlify/images?url=_astro%2Fwedding-hero.ChW2o0Fy.webp&#38;fm=webp&#38;w=640&#38;h=427&#38;q=75" as="image" media="(max-width: 640px)" />
		<link rel="preload" href="/.netlify/images?url=_astro%2Fwedding-hero.ChW2o0Fy.webp&#38;fm=webp&#38;w=1024&#38;h=683&#38;q=75" as="image" media="(min-width: 641px) and (max-width: 1024px)" />
		<link rel="preload" href="/.netlify/images?url=_astro%2Fwedding-hero.ChW2o0Fy.webp&#38;fm=webp&#38;w=2070&#38;h=1380&#38;q=75" as="image" media="(min-width: 1025px)" />

		<!-- Google Tag Manager & GA4 deferred intelligently after first interaction or timeout -->
		<script is:inline>
		window.addEventListener('DOMContentLoaded', function() {
			// Hilo de carga diferido para herramientas de Google
			function loadGoogleScripts() {
				if (window.googleScriptsLoaded) return;
				window.googleScriptsLoaded = true;

				// 1. Google Tag Manager
				(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
				new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
				j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
				'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
				})(window,document,'script','dataLayer','GTM-P5F9NFNR');

				// 2. Google Analytics (gtag.js)
				var s = document.createElement('script');
				s.async = true;
				s.src = 'https://www.googletagmanager.com/gtag/js?id=G-NLSP38RBXJ';
				document.head.appendChild(s);
				s.onload = function() {
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					window.gtag = gtag;
					gtag('js', new Date());
					gtag('config', 'G-NLSP38RBXJ');
				};
			}

			// Disparar la carga ante la primera interacción física del usuario o un tiempo límite de 2.5s
			const triggerEvents = ['pointerdown', 'touchstart', 'scroll', 'mousemove', 'keydown'];
			triggerEvents.forEach(function(event) {
				window.addEventListener(event, loadGoogleScripts, { once: true, passive: true });
			});

			// Carga de respaldo si no hay interacción en 2.5 segundos
			setTimeout(loadGoogleScripts, 2500);
		});
		</script>

		<!-- Meta Pixel Code - deferred -->
		<script is:inline>
		window.addEventListener('DOMContentLoaded', function() {
			!function(f,b,e,v,n,t,s)
			{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
			n.callMethod.apply(n,arguments):n.queue.push(arguments)};
			if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
			n.queue=[];t=b.createElement(e);t.async=!0;
			t.src=v;s=b.getElementsByTagName(e)[0];
			s.parentNode.insertBefore(t,s)}(window, document,'script',
			'https://connect.facebook.net/en_US/fbevents.js');
			fbq('init', '1523091419179735');
			fbq('track', 'PageView');
		});
		</script>
		<noscript><img height="1" width="1" style="display:none"
		src="https://www.facebook.com/tr?id=1523091419179735&ev=PageView&noscript=1"
		/></noscript>

		<script is:inline>
		window.trackInitiateCheckout = function() {
			if (window.fbq) {
				fbq('track', 'InitiateCheckout');
			}
			if (window.gtag) {
				gtag('event', 'begin_checkout', {
					currency: 'USD',
					value: 297.00,
					items: [{
						item_id: 'master_wedding_planner',
						item_name: 'Inscripción Máster Wedding Planner',
						item_category: 'Educación',
						price: 297.00,
						quantity: 1
					}]
				});
			}
		};
		</script>
	</head>
	<body class="font-sans text-slate-800 bg-slate-50 antialiased">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P5F9NFNR"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		
		<slot />
		
		<!-- WhatsApp Floating Bar -->
		{ !isCheckout && <FloatingBar /> }
	</body>
</html>

<style is:global>
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Merriweather', serif;
	}
	
	/* Custom scrollbar for webkit */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: #f1f5f9; 
	}
	::-webkit-scrollbar-thumb {
		background: #cbd5e1; 
		border-radius: 4px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #94a3b8; 
	}
</style>
