---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImage from '../images/logo.webp';
import { User, Phone } from '@lucide/astro';
---

<Layout title="Herramientas Gratuitas para Wedding Planners | Instituto Osbord">
  <main class="relative min-h-screen flex items-center justify-center bg-navy py-12 px-4">

    <!-- Decorative gold orbs -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-gold/10 rounded-full blur-[120px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-gold/8 rounded-full blur-[100px] translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 w-[600px] h-[300px] bg-white/2 rounded-full blur-[80px] -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

    <!-- Subtle grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(#D4AF37 1px, transparent 1px), linear-gradient(90deg, #D4AF37 1px, transparent 1px); background-size: 50px 50px;"></div>

    <div class="relative z-10 w-full max-w-md">

      <!-- Logo Brand Block -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center gap-3 justify-center mb-3">
          <Image src={logoImage} alt="Instituto Osbord Logo" class="h-14 w-auto object-contain drop-shadow-xl" />
        </div>
        <p class="text-slate-400 text-xs tracking-[0.2em] uppercase font-medium">Instituto Osbord</p>
        <div class="mt-4 h-px w-16 bg-gradient-to-r from-transparent via-gold to-transparent mx-auto opacity-60"></div>
      </div>

      <!-- Main Card -->
      <div class="relative bg-navy-light/60 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-10 shadow-2xl shadow-black/40">

        <!-- Subtle inner glow -->
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-gold/5 via-transparent to-transparent pointer-events-none"></div>

        <!-- Content -->
        <div class="relative z-10 space-y-7">

          <!-- Badge + Heading -->
          <div class="text-center space-y-4">
            <span class="inline-flex items-center gap-2 text-[10px] font-bold tracking-[0.18em] text-gold uppercase bg-gold/10 border border-gold/20 px-4 py-1.5 rounded-full">
              <span class="text-base">🎁</span> Recurso Gratuito Exclusivo
            </span>

            <h1 class="text-xl md:text-2xl font-serif font-bold text-white leading-tight">
              Descarga la Plantilla Automatizada y el Checklist Profesional para Wedding Planners
            </h1>

            <p class="text-slate-400 text-xs md:text-sm leading-relaxed font-sans">
              Optimiza tus tiempos, cotiza con precisión y gestiona cada detalle de tus eventos sin margen de error. Recibe tus herramientas directamente en tu WhatsApp.
            </p>
          </div>

          <!-- Divider -->
          <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

          <!-- Form -->
          <div x-data="{
            nombreUsuario: '',
            whatsappUsuario: '+57',
            sending: false,
            get isFormValid() {
              return this.nombreUsuario.trim() !== '' && this.whatsappUsuario.trim() !== '' && this.whatsappUsuario.trim() !== '+57';
            },
            async handleSubmit() {
              if (!this.isFormValid || this.sending) return;
              this.sending = true;

              const payload = JSON.stringify({
                nombre: this.nombreUsuario.trim(),
                telefono: this.whatsappUsuario.trim(),
                email: 'Lead_WhatsApp@noemail.com',
                origen: 'weddingcol_lead',
                page_url: window.location.href,
                user_agent: navigator.userAgent
              });

              try {
                await Promise.race([
                  fetch('https://script.google.com/macros/s/AKfycbyYsqNrX5V08QAl3Cp7oUD0_unWsUpFIqhpSvnZ5ChkcIsf55Z9KOTLftDGFo-E-A/exec', {
                    method: 'POST',
                    mode: 'no-cors',
                    keepalive: true,
                    headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                    body: payload
                  }),
                  new Promise(resolve => setTimeout(resolve, 1500))
                ]);
              } catch (e) {
                console.error('[Google Sheets] Error:', e);
              }

              window.location.href = "https://chat.whatsapp.com/B687JdfCFUb6U6WCe2bmEd?s=cl&p=i&mlu=0";
            }
          }" class="space-y-5">

            <!-- Name Input -->
            <div class="space-y-1.5">
              <label for="input_nombre" class="block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">
                Nombre Completo
              </label>
              <div class="relative group">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-gold transition-colors">
                  <User class="w-4 h-4" />
                </div>
                <input 
                  type="text" 
                  id="input_nombre" 
                  x-model="nombreUsuario"
                  placeholder="Ej. Ana María Silva" 
                  class="w-full bg-navy/70 border border-white/10 text-white placeholder-slate-600 rounded-xl py-3.5 pl-11 pr-4 text-sm focus:outline-none focus:border-gold/50 focus:ring-1 focus:ring-gold/30 focus:bg-navy transition-all font-sans"
                />
              </div>
            </div>

            <!-- WhatsApp Input -->
            <div class="space-y-1.5">
              <label for="input_whatsapp" class="block text-[10px] font-bold uppercase tracking-[0.15em] text-slate-400">
                WhatsApp (con código de país)
              </label>
              <div class="relative group">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-gold transition-colors">
                  <Phone class="w-4 h-4" />
                </div>
                <input 
                  type="tel" 
                  id="input_whatsapp" 
                  x-model="whatsappUsuario"
                  placeholder="Ej. +573001234567" 
                  class="w-full bg-navy/70 border border-white/10 text-white placeholder-slate-600 rounded-xl py-3.5 pl-11 pr-4 text-sm focus:outline-none focus:border-gold/50 focus:ring-1 focus:ring-gold/30 focus:bg-navy transition-all font-sans"
                />
              </div>
            </div>

            <!-- Urgency Note -->
            <p class="text-center text-slate-500 text-[11px] leading-relaxed font-sans px-2">
              Al registrarte, serás redirigido automáticamente a nuestro grupo oficial de acceso.
            </p>

            <!-- CTA Button -->
            <button 
              @click="handleSubmit()"
              :disabled="!isFormValid || sending"
              class="group relative w-full font-bold text-sm md:text-base py-4 px-6 rounded-xl transition-all duration-300 flex items-center justify-center gap-2.5 overflow-hidden bg-gradient-to-r from-gold to-gold-dark text-navy shadow-lg shadow-gold/20 hover:shadow-xl hover:shadow-gold/30 hover:scale-[1.02] active:scale-[0.98] cursor-pointer"
              :class="(!isFormValid || sending) ? 'opacity-50 cursor-not-allowed hover:scale-100' : ''"
            >
              <!-- Shimmer effect on hover -->
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 pointer-events-none"></div>

              <!-- Spinner -->
              <svg x-show="sending" style="display:none;" class="animate-spin h-5 w-5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>

              <span x-text="sending ? 'Enviando...' : '¡Obtener Mis Herramientas Gratis! 🚀'" class="relative z-10 uppercase tracking-wide">
                ¡Obtener Mis Herramientas Gratis! 🚀
              </span>
            </button>

          </div>

        </div>
      </div>

      <!-- Footer trust note -->
      <p class="mt-6 text-center text-slate-600 text-[11px] flex items-center justify-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-emerald-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Tus datos están protegidos y no serán compartidos con terceros.
      </p>

    </div>
  </main>
</Layout>
