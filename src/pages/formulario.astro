---
export const prerender = true;

import { Image } from 'astro:assets';
import logoImage from '../images/logo.webp';
import { User, Phone } from '@lucide/astro';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="Descarga gratis la Plantilla Automatizada y el Checklist Profesional para Wedding Planners — Instituto Osbord" />
  <title>Herramientas Gratuitas para Wedding Planners | Instituto Osbord</title>
  <link rel="icon" type="image/webp" href="/images/logofaviconosbord.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@700&display=swap" rel="stylesheet" />
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Inter', sans-serif;
      background-color: #0F172A;
      color: #f8fafc;
      min-height: 100vh;
    }
    .font-serif { font-family: 'Merriweather', serif; }

    /* Layout */
    .page-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 1rem;
      position: relative;
      overflow: hidden;
      background-color: #0F172A;
    }

    /* Orbs */
    .orb {
      position: absolute;
      border-radius: 9999px;
      pointer-events: none;
    }
    .orb-1 { top: -200px; left: -200px; width: 500px; height: 500px; background: rgba(212,175,55,0.10); filter: blur(120px); }
    .orb-2 { bottom: -150px; right: -150px; width: 400px; height: 400px; background: rgba(212,175,55,0.07); filter: blur(100px); }

    /* Grid overlay */
    .grid-overlay {
      position: absolute; inset: 0; pointer-events: none; opacity: 0.03;
      background-image: linear-gradient(#D4AF37 1px,transparent 1px), linear-gradient(90deg,#D4AF37 1px,transparent 1px);
      background-size: 50px 50px;
    }

    .card-wrap { position: relative; z-index: 10; width: 100%; max-width: 448px; }

    /* Logo block */
    .logo-block { text-align: center; margin-bottom: 2rem; }
    .logo-block img { height: 56px; width: auto; object-fit: contain; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.5)); }
    .logo-label { color: #94a3b8; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 500; margin-top: 8px; }
    .logo-divider { margin: 12px auto 0; height: 1px; width: 64px; background: linear-gradient(to right, transparent, #D4AF37, transparent); opacity: 0.6; }

    /* Card */
    .card {
      position: relative;
      background: rgba(30,41,59,0.60);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 24px;
      padding: 2.5rem;
      box-shadow: 0 25px 50px rgba(0,0,0,0.45);
    }
    .card-glow {
      position: absolute; inset: 0; border-radius: 24px; pointer-events: none;
      background: linear-gradient(135deg, rgba(212,175,55,0.06), transparent);
    }
    .card-content { position: relative; z-index: 10; }

    /* Badge */
    .badge {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
      color: #D4AF37;
      background: rgba(212,175,55,0.10);
      border: 1px solid rgba(212,175,55,0.20);
      padding: 6px 16px; border-radius: 9999px;
    }

    /* Headings */
    h1 { font-size: 1.25rem; line-height: 1.35; color: #fff; margin: 1rem 0 0.5rem; }
    @media (min-width: 640px) { h1 { font-size: 1.5rem; } }
    .subtitle { color: #94a3b8; font-size: 13px; line-height: 1.6; }

    /* Divider */
    .section-divider { height: 1px; background: linear-gradient(to right, transparent, rgba(255,255,255,0.10), transparent); margin: 1.5rem 0; }

    /* Form */
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #64748b; }
    .input-wrap { position: relative; }
    .input-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #475569; pointer-events: none; width: 16px; height: 16px; transition: color 0.2s; }
    .form-input {
      width: 100%;
      background: rgba(15,23,42,0.70);
      border: 1px solid rgba(255,255,255,0.10);
      color: #fff;
      border-radius: 12px;
      padding: 14px 16px 14px 44px;
      font-size: 14px;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .form-input::placeholder { color: #334155; }
    .form-input:focus { border-color: rgba(212,175,55,0.50); box-shadow: 0 0 0 3px rgba(212,175,55,0.12); background: #0F172A; }
    .form-input:focus + .input-icon, .input-wrap:focus-within .input-icon { color: #D4AF37; }

    /* Note */
    .form-note { font-size: 11px; color: #475569; text-align: center; line-height: 1.6; padding: 0 8px; }

    /* Button */
    .btn-submit {
      position: relative; overflow: hidden;
      width: 100%;
      padding: 16px 24px;
      border: none;
      border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      cursor: not-allowed;
      transition: all 0.3s;
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .btn-submit.disabled-state {
      background: rgba(255,255,255,0.06);
      color: #475569;
      box-shadow: none;
    }
    .btn-submit.active-state {
      background: linear-gradient(135deg, #D4AF37, #B89628);
      color: #0F172A;
      box-shadow: 0 8px 25px rgba(212,175,55,0.25);
      cursor: pointer;
    }
    .btn-submit.active-state:hover {
      transform: scale(1.02);
      box-shadow: 0 12px 35px rgba(212,175,55,0.35);
    }
    .btn-submit.active-state:active { transform: scale(0.98); }

    /* Shimmer */
    .btn-shimmer {
      position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s;
      pointer-events: none;
    }
    .btn-submit.active-state:hover .btn-shimmer { transform: translateX(100%); }

    /* Spinner */
    .spinner { width: 20px; height: 20px; flex-shrink: 0; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Footer note */
    .trust-note {
      margin-top: 1.5rem;
      text-align: center;
      font-size: 11px;
      color: #334155;
      display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .trust-icon { width: 14px; height: 14px; color: #10b981; flex-shrink: 0; }

    .space-y-6 > * + * { margin-top: 1.5rem; }
    .space-y-5 > * + * { margin-top: 1.25rem; }
    .text-center { text-align: center; }
  </style>
</head>
<body>
  <div class="page-wrap">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="grid-overlay"></div>

    <div class="card-wrap">
      <!-- Logo -->
      <div class="logo-block">
        <Image src={logoImage} alt="Instituto Osbord" />
        <p class="logo-label">Instituto Osbord</p>
        <div class="logo-divider"></div>
      </div>

      <!-- Card -->
      <div class="card">
        <div class="card-glow"></div>
        <div class="card-content space-y-6">

          <!-- Header -->
          <div class="text-center space-y-5">
            <span class="badge"><span style="font-size:1rem;">🎁</span> Recurso Gratuito Exclusivo</span>
            <h1 class="font-serif">Descarga la Plantilla Automatizada y el Checklist Profesional para Wedding Planners</h1>
            <p class="subtitle">Optimiza tus tiempos, cotiza con precisión y gestiona cada detalle de tus eventos sin margen de error. Recibe tus herramientas directamente en tu WhatsApp.</p>
          </div>

          <div class="section-divider"></div>

          <!-- Form -->
          <div
            x-data="{
              nombreUsuario: '',
              whatsappUsuario: '+57',
              sending: false,
              get isFormValid() {
                return this.nombreUsuario.trim().length > 0 && this.whatsappUsuario.trim().length > 3 && this.whatsappUsuario.trim() !== '+57';
              },
              async handleSubmit() {
                if (!this.isFormValid || this.sending) return;
                this.sending = true;
                const payload = JSON.stringify({
                  nombre: this.nombreUsuario.trim(),
                  telefono: this.whatsappUsuario.trim(),
                  email: 'Lead_WhatsApp@noemail.com',
                  origen: 'weddingcol_lead',
                  page_url: window.location.href,
                  user_agent: navigator.userAgent
                });
                try {
                  await Promise.race([
                    fetch('https://script.google.com/macros/s/AKfycbyYsqNrX5V08QAl3Cp7oUD0_unWsUpFIqhpSvnZ5ChkcIsf55Z9KOTLftDGFo-E-A/exec', {
                      method: 'POST', mode: 'no-cors', keepalive: true,
                      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                      body: payload
                    }),
                    new Promise(r => setTimeout(r, 1500))
                  ]);
                } catch(e) { console.error(e); }
                window.location.href = 'https://chat.whatsapp.com/B687JdfCFUb6U6WCe2bmEd?s=cl&p=i&mlu=0';
              }
            }"
            class="space-y-5"
          >
            <!-- Nombre -->
            <div class="form-group">
              <label for="inp_nombre" class="form-label">Nombre Completo</label>
              <div class="input-wrap">
                <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input
                  id="inp_nombre"
                  type="text"
                  x-model="nombreUsuario"
                  placeholder="Ej. Ana María Silva"
                  class="form-input"
                  autocomplete="name"
                />
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="form-group">
              <label for="inp_whatsapp" class="form-label">WhatsApp Colombia (+57)</label>
              <div class="input-wrap">
                <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <input
                  id="inp_whatsapp"
                  type="tel"
                  x-model="whatsappUsuario"
                  placeholder="+573001234567"
                  class="form-input"
                  autocomplete="tel"
                />
              </div>
            </div>

            <p class="form-note">Al registrarte, serás redirigido automáticamente a nuestro grupo oficial de acceso.</p>

            <!-- CTA -->
            <button
              @click="handleSubmit()"
              :disabled="!isFormValid || sending"
              class="btn-submit"
              :class="isFormValid && !sending ? 'active-state' : 'disabled-state'"
            >
              <div class="btn-shimmer"></div>

              <svg x-show="sending" x-cloak class="spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle style="opacity:0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path style="opacity:0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>

              <span x-text="sending ? 'Enviando...' : '¡Obtener Mis Herramientas Gratis! 🚀'">¡Obtener Mis Herramientas Gratis! 🚀</span>
            </button>

          </div>
        </div>
      </div>

      <!-- Trust -->
      <p class="trust-note">
        <svg class="trust-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Tus datos están protegidos y no serán compartidos con terceros.
      </p>
    </div>
  </div>
</body>
</html>
